# Application
APP_NAME=Notification Service
APP_VERSION=1.0.0
DEBUG=True
ENVIRONMENT=development

# Server
HOST=0.0.0.0
PORT=8004

# Database
DATABASE_URL=postgresql+asyncpg://notification_user:notification_password@localhost:5432/notification_service_db

# Redis (для shared/auth_lib blacklist - должен совпадать со всеми сервисами)
JWT_BLACKLIST_REDIS_URL=redis://localhost:6379/15

# JWT (должен совпадать с Auth Service)
JWT_SECRET_KEY=your-secret-key-change-in-production
JWT_ALGORITHM=HS256

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
CORS_ALLOW_CREDENTIALS=True

# RabbitMQ (используется со Дня 2)
RABBITMQ_URL=amqp://guest:guest@localhost:5672/