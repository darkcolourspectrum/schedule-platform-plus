# Profile Service Environment Variables

# === DATABASE SETTINGS ===
DATABASE_URL=postgresql+asyncpg://profile_user:profile_password@localhost:5432/profile_service_db
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=profile_service_db
DATABASE_USER=profile_user
DATABASE_PASSWORD=profile_password

# === REDIS SETTINGS ===
REDIS_URL=redis://localhost:6379/2
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=2

# === APPLICATION SETTINGS ===
APP_NAME=Profile Service
APP_VERSION=1.0.0
DEBUG=True
ENVIRONMENT=development

# === CORS SETTINGS ===
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:8080","http://localhost:5173"]
ALLOW_CREDENTIALS=true

# === MICROSERVICES INTEGRATION ===
AUTH_SERVICE_URL=http://localhost:8000
AUTH_SERVICE_TIMEOUT=30

# === PROFILE SERVICE SPECIFIC ===
MAX_AVATAR_SIZE_MB=5
ALLOWED_IMAGE_TYPES=["image/jpeg","image/png","image/webp"]
AVATAR_UPLOAD_PATH=static/avatars

# === CACHE TTL SETTINGS (в секундах) ===
CACHE_USER_PROFILE_TTL=600


# === SECURITY ===
# ВАЖНО: Используйте тот же ключ что и в других сервисах!
INTERNAL_API_KEY=your-internal-api-key-change-this-in-production