# ==================== VK Bot Service ====================
# Пример переменных окружения. Скопируйте в .env и заполните.
# В docker-compose большинство значений приходит из окружения compose;
# этот файл - для локального запуска без docker.

# --- Application ---
APP_NAME=VK Bot Service
APP_VERSION=1.0.0
DEBUG=true
ENVIRONMENT=development
HOST=0.0.0.0
PORT=8006

# --- Database (своя БД сервиса) ---
DATABASE_URL=postgresql+asyncpg://vk_bot_user:vk_bot_password@postgres:5432/vk_bot_service_db

# --- JWT (должен совпадать с Auth Service) ---
JWT_SECRET_KEY=change-me-must-match-auth-service
JWT_ALGORITHM=HS256
JWT_BLACKLIST_REDIS_URL=redis://redis:6379/15

# --- Internal API key (межсервисные вызовы bot -> auth/crm/schedule) ---
INTERNAL_API_KEY=change-me-must-match-other-services

# --- VK сообщество (НЕ приложение VK ID!) ---
# Токен доступа сообщества: настройки сообщества -> Работа с API ->
# Ключи доступа. Нужны права на сообщения. group_id - числовой id группы.
# Long Poll API включается там же (Работа с API -> Long Poll API),
# тип событий message_new, последняя версия API.
VK_GROUP_TOKEN=
VK_GROUP_ID=0
VK_API_VERSION=5.199
VK_LONGPOLL_WAIT=25

# ID студии по умолчанию для заявок из бота (0 = не проставлять).
VK_DEFAULT_STUDIO_ID=0

# --- External services (внутренняя сеть docker) ---
AUTH_SERVICE_URL=http://auth-service:8000
CRM_SERVICE_URL=http://crm-service:8005
SCHEDULE_SERVICE_URL=http://schedule-service:8001
EXTERNAL_SERVICE_TIMEOUT=10.0

# --- CORS ---
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost
CORS_ALLOW_CREDENTIALS=true

# --- RabbitMQ ---
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/

# --- Outbound retry worker ---
OUTBOUND_POLL_INTERVAL_SECONDS=5.0
OUTBOUND_BATCH_SIZE=50
OUTBOUND_MAX_ATTEMPTS=5
